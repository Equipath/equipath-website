---
const audiences = [
  {
    icon: `<path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`,
    title: "Business Owners",
    description: "Managing multiple entities across jurisdictions? See everything in one place.",
  },
  {
    icon: `<path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a2 2 0 100-4 2 2 0 000 4z" />`,
    title: "Family Offices",
    description: "Complex ownership structures deserve a dedicated tool. Map and manage every layer.",
  },
  {
    icon: `<path d="M13 10V3L4 14h7v7l9-11h-7z" />`,
    title: "Entrepreneurs",
    description: "Expanding your portfolio? Scale from one entity to fifty without changing your workflow.",
  },
  {
    icon: `<path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />`,
    title: "Anyone Tired of Spreadsheets",
    description: "If you've ever missed a filing deadline or lost track of a document, this is for you.",
  },
];
---

<section id="who-its-for" class="relative py-28 sm:py-36 bg-bg">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section Header -->
    <div class="fade-up text-center mb-16">
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-4 text-text">
        Built for
        <span class="font-serif italic font-normal text-text-muted">those who build.</span>
      </h2>
      <p class="text-text-muted text-lg max-w-xl mx-auto">
        Whether you manage one entity or one hundred.
      </p>
    </div>

    <!-- Audience Grid -->
    <div class="grid sm:grid-cols-2 gap-5 stagger">
      {audiences.map((audience) => (
        <div class="fade-up card-hover rounded-2xl border border-border bg-bg-card p-7 flex gap-5">
          <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-accent-dim flex items-center justify-center">
            <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={audience.icon} />
            </svg>
          </div>
          <div>
            <h3 class="font-display font-semibold text-lg mb-1.5 text-text">{audience.title}</h3>
            <p class="text-text-muted text-sm leading-relaxed">{audience.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
