---
const currentYear = new Date().getFullYear();
---

<footer class="dark-section border-t border-white/5 py-12">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <!-- Logo + Tagline -->
      <div class="flex items-center gap-6">
        <a href="#" class="flex items-center">
          <img
            src="/assets/images/logo-white.png"
            alt="EquiPath"
            width="1153"
            height="211"
            class="h-7 w-auto opacity-70 hover:opacity-90 transition-opacity"
          />
        </a>
        <span class="hidden sm:inline text-white/40 text-sm">
          Simplifying entity management for modern businesses.
        </span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm text-white/50">
        <a href="#features" class="hover:text-white/80 transition-colors">Features</a>
        <a href="#how-it-works" class="hover:text-white/80 transition-colors">How It Works</a>
        <a href="#get-started" class="hover:text-white/80 transition-colors">Get Started</a>
      </div>
    </div>

    <!-- Legal Links -->
    <div class="mt-8 pt-6 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/30 text-xs">
        &copy; {currentYear} Equipath Services. All rights reserved.
      </p>
      <div class="flex flex-wrap justify-center gap-x-5 gap-y-1 text-xs text-white/40">
        <a href="https://app.equipath.online/legal/privacy" class="hover:text-white/70 transition-colors">Privacy Policy</a>
        <a href="https://app.equipath.online/legal/terms" class="hover:text-white/70 transition-colors">Terms of Service</a>
        <a href="https://app.equipath.online/legal/data-retention" class="hover:text-white/70 transition-colors">Data Retention</a>
        <a href="https://app.equipath.online/legal/incident-response" class="hover:text-white/70 transition-colors">Incident Response</a>
        <a href="https://app.equipath.online/legal/contact" class="hover:text-white/70 transition-colors">Contact</a>
      </div>
    </div>
  </div>
</footer>
