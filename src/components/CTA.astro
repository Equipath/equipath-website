---
---

<section id="get-started" class="dark-section relative py-28 sm:py-36 overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none" aria-hidden="true">
    <div class="w-[600px] h-[600px] rounded-full bg-white/3 blur-[120px]"></div>
  </div>

  <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
    <div class="fade-up">
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-4 text-white">
        <span class="font-serif italic font-normal text-white/50">Stop</span>
        Managing Entities
        <br />
        in
        <span class="gradient-text">Spreadsheets.</span>
      </h2>
    </div>

    <!-- Free Callout -->
    <div class="fade-up max-w-xl mx-auto mb-12">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-white/15 bg-white/5 mb-5">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        <span class="text-sm text-white/70 font-medium">Free forever for core features</span>
      </div>
      <p class="text-white/50 text-base max-w-lg mx-auto">
        Entity management, compliance tracking, ownership mapping, filings, and registrations — all free.
        No credit card. No trial. No catch.
      </p>
    </div>

    <!-- Free vs Premium -->
    <div class="fade-up grid sm:grid-cols-2 gap-4 max-w-lg mx-auto mb-12">
      <!-- Free Column -->
      <div class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm p-6 text-left">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl font-bold text-white">$0</span>
          <span class="text-white/40 text-sm">/ forever</span>
        </div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/60 mb-3">Core — included free</h3>
        <ul class="space-y-2 text-sm text-white/70">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-green-400 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            Entity organization
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-green-400 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            Compliance calendar
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-green-400 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            Ownership mapping
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-green-400 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            Filings &amp; registrations
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-green-400 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            Post-quantum encryption
          </li>
        </ul>
      </div>

      <!-- Premium Column -->
      <div id="pricing" class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm p-6 text-left">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl font-bold text-white">$7–10</span>
          <span class="text-white/40 text-sm">/ entity / mo</span>
        </div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/60 mb-3">Premium — per entity</h3>
        <ul class="space-y-2 text-sm text-white/70">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-accent-bright shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V7z" clip-rule="evenodd" /></svg>
            Document storage
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-accent-bright shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V7z" clip-rule="evenodd" /></svg>
            Share &amp; permissions
          </li>
        </ul>
      </div>
    </div>

    <!-- CTA -->
    <div class="fade-up">
      <a
        href="https://app.equipath.online/register"
        class="group inline-flex items-center gap-2 px-8 py-3.5 rounded-full bg-white text-[#062b5c] font-semibold hover:bg-white/90 transition-colors"
      >
        Get Started Free
        <svg class="w-4 h-4 cta-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 12L12 4M12 4H6M12 4v6" />
        </svg>
      </a>
      <p class="text-white/30 text-xs mt-4">
        No credit card required. Free for core features, always.
      </p>
    </div>
  </div>
</section>
