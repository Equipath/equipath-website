---
---

<section id="get-started" class="dark-section relative py-28 sm:py-36 overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none" aria-hidden="true">
    <div class="w-[600px] h-[600px] rounded-full bg-white/3 blur-[120px]"></div>
  </div>

  <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
    <div class="fade-up">
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-4 text-white">
        <span class="font-serif italic font-normal text-white/50">Stop</span>
        Managing Entities
        <br />
        in
        <span class="gradient-text">Spreadsheets.</span>
      </h2>
      <p class="text-white/60 text-lg max-w-xl mx-auto mb-10">
        Free for core features. Premium sharing and document storage
        available when you need them.
      </p>
    </div>

    <!-- CTA Card -->
    <div class="fade-up max-w-md mx-auto rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm p-8">
      <form class="space-y-5" action="https://app.equipath.online/register" method="get">
        <!-- Entity Count -->
        <div class="text-left">
          <label for="entity-count" class="block text-sm text-white/60 mb-2">
            How many entities do you manage?
          </label>
          <select
            id="entity-count"
            name="entities"
            class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/15 text-white text-sm focus:outline-none focus:border-white/30 focus:ring-1 focus:ring-white/10 transition-colors appearance-none cursor-pointer"
          >
            <option value="1-10">1 – 10 entities</option>
            <option value="11-20">11 – 20 entities</option>
            <option value="21-50">21 – 50 entities</option>
            <option value="51-100">51 – 100 entities</option>
            <option value="101+">101+ entities</option>
          </select>
        </div>

        <!-- Submit -->
        <button
          type="submit"
          class="group w-full inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-full bg-white text-[#062b5c] font-semibold hover:bg-white/90 transition-colors"
        >
          Get Started Free
          <svg class="w-4 h-4 cta-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 12L12 4M12 4H6M12 4v6" />
          </svg>
        </button>
      </form>

      <p class="text-white/30 text-xs mt-4">
        No credit card required.
      </p>
    </div>
  </div>
</section>
