---
---

<section class="dark-section relative min-h-screen flex items-center justify-center pt-16 overflow-hidden">
  <!-- Ambient Blobs -->
  <div class="blob blob-1" aria-hidden="true"></div>
  <div class="blob blob-2" aria-hidden="true"></div>
  <div class="blob blob-3" aria-hidden="true"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <!-- Headline -->
    <h1 class="fade-up font-display text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.1] mb-6 text-white">
      <span class="font-serif italic font-normal text-white/60">Simplified</span>
      <br />
      Entity Management
      <br />
      <span class="gradient-text">&amp; Compliance.</span>
    </h1>

    <!-- Subheading -->
    <p class="fade-up max-w-2xl mx-auto text-lg sm:text-xl text-white/60 leading-relaxed mb-10">
      Manage your LLCs, corporations, and organizational records — all in one
      secure, post-quantum encrypted platform.
    </p>

    <!-- CTAs -->
    <div class="fade-up flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#get-started"
        class="group inline-flex items-center gap-2 px-8 py-3.5 rounded-full bg-white text-[#062b5c] font-semibold hover:bg-white/90 transition-colors"
      >
        Get Started Free
        <svg class="w-4 h-4 cta-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 12L12 4M12 4H6M12 4v6" />
        </svg>
      </a>
      <a
        href="https://app.equipath.online"
        class="text-sm text-white/50 hover:text-white/80 transition-colors underline underline-offset-4 decoration-white/20 hover:decoration-white/40"
      >
        Already have an account? Sign in
      </a>
    </div>

    <!-- Scroll Prompt -->
    <div class="fade-up mt-20 flex flex-col items-center gap-2 text-white/30">
      <span class="text-xs uppercase tracking-widest">Discover More</span>
      <svg class="w-5 h-5 animate-bounce" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M10 4v12M4 10l6 6 6-6" />
      </svg>
    </div>
  </div>
</section>
